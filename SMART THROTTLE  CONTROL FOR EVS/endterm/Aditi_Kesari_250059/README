%EV SMART THROTTLE
% Includes:
% 1. Plant Model
% 2. PID Analysis (Kp, Ki, Kd variation)
% 3. Final PID Design
% 4. Gain Scheduling
% 5. Comparison Plot

clc;
clear;
close all;

% CREATE RESULTS FOLDER

if ~exist('results','dir')
    mkdir('results');
end

% PLANT MODEL

K = 1;
tau = 0.5;

G = tf(K,[tau 1]);

figure;
step(G);
title('Open Loop Response');
xlabel('Time (seconds)');
ylabel('Motor Speed');
grid on;

saveas(gcf,'results/open_loop_response.png');

% EFFECT OF Kp

Kp_values = [0.5 1 2 4 6];

figure;
hold on; grid on;

for i = 1:length(Kp_values)
    C = pid(Kp_values(i),0,0);
    T = feedback(C*G,1);
    step(T);
end

title('Effect of Kp Variation');
legend('0.5','1','2','4','6');
xlabel('Time'); ylabel('Output');

% EFFECT OF Ki

Kp = 2;
Ki_values = [0.5 1 2 4 6];

figure;
hold on; grid on;

for i = 1:length(Ki_values)
    C = pid(Kp,Ki_values(i),0);
    T = feedback(C*G,1);
    step(T);
end

title('Effect of Ki Variation');
legend('0.5','1','2','4','6');
xlabel('Time'); ylabel('Output');

% EFFECT OF Kd

Kp = 2; Ki = 2;
Kd_values = [0.01 0.05 0.1 0.2 0.5];

figure;
hold on; grid on;

for i = 1:length(Kd_values)
    C = pid(Kp,Ki,Kd_values(i));
    T = feedback(C*G,1);
    step(T);
end

title('Effect of Kd Variation');
legend('0.01','0.05','0.1','0.2','0.5');
xlabel('Time'); ylabel('Output');

% FINAL PID DESIGN

Kp = 3;
Ki = 2;
Kd = 0.1;

C = pid(Kp,Ki,Kd);
T_pid = feedback(C*G,1);

figure;
step(T_pid);
title('Final PID Response');
xlabel('Time'); ylabel('Motor Speed');
grid on;

saveas(gcf,'results/pid_response.png');

info = stepinfo(T_pid)

% GAIN SCHEDULING

% Define zones
zone1 = [2 3 0.05];
zone2 = [3 2 0.1];
zone3 = [4 1 0.15];

% Time segments
t1 = 0:0.01:5;
t2 = 5:0.01:10;
t3 = 10:0.01:15;

% Throttle levels
u1 = 0.2;
u2 = 0.5;
u3 = 0.85;

% Controllers
C1 = pid(zone1(1),zone1(2),zone1(3));
C2 = pid(zone2(1),zone2(2),zone2(3));
C3 = pid(zone3(1),zone3(2),zone3(3));

T1 = feedback(C1*G,1);
T2 = feedback(C2*G,1);
T3 = feedback(C3*G,1);

% Responses
[y1,t_out1] = step(T1,t1);
y2 = step(T2,t2-5);
y3 = step(T3,t3-10);

y1 = y1*u1;
y2 = y2*u2;
y3 = y3*u3;

time = [t_out1; t2'; t3'];
speed = [y1; y2; y3];

figure;
plot(time,speed,'LineWidth',2);
hold on; grid on;

xline(5,'--r','Zone1→Zone2');
xline(10,'--r','Zone2→Zone3');

title('Gain Scheduled Response');
xlabel('Time'); ylabel('Motor Speed');

saveas(gcf,'results/gainscheduled_response.png');

% COMPARISON PLOT

% Gain scheduled approximation
T_gs = (T1 + T2 + T3)/3;

figure;
hold on;

step(G,'r--');
step(T_pid,'b');
step(T_gs,'g');

legend('Open-loop','PID','Gain-Scheduled');
title('Comparison Plot');
xlabel('Time'); ylabel('Motor Speed');
grid on;

saveas(gcf,'results/comparison_plot.png');

% END OF SCRIPT
